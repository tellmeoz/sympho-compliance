# Credenciales Públicas de Supabase (Cliente Frontend y Backend)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica-de-supabase

# Credencial Administrativa Privada (SOLO BACKEND - Salta RLS)
# ¡NUNCA expongas esta clave en el cliente!
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-privada-de-supabase

# URL Base de la Aplicación (Para control de CORS y Origen CSRF)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secreto de Firmas para la Cookie de Sesión Encriptada
# Genera un string aleatorio largo (mínimo 32 caracteres)
JWT_SECRET=escribe-aqui-un-secreto-seguro-y-largo-de-32-caracteres

# Secreto de Autorización para el Job Cron de decaimiento diario
# El header 'Authorization: Bearer <CRON_SECRET>' debe coincidir
CRON_SECRET=secreto-para-el-cron-job-de-time-decay
